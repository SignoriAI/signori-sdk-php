{
    "name": "signvault/signvault-php",
    "description": "Official PHP SDK for the SignVault e-signature API",
    "type": "library",
    "license": "MIT",
    "keywords": ["signvault", "e-signature", "esign", "pdf", "signing"],
    "homepage": "https://github.com/kmorganisation/signvault-sdk-php",
    "authors": [
        {
            "name": "SignVault",
            "email": "dev@signvault.com"
        }
    ],
    "require": {
        "php": ">=8.1",
        "psr/http-client": "^1.0",
        "psr/http-message": "^2.0",
        "psr/http-factory": "^1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5 || ^11.0",
        "nyholm/psr7": "^1.8"
    },
    "autoload": {
        "psr-4": {
            "SignVault\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SignVault\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "test:unit": "phpunit --testsuite Unit",
        "test:integration": "phpunit --testsuite Integration"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {}
    },
    "minimum-stability": "stable"
}
